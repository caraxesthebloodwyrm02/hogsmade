{
  "name": "@cascade/shared-resilience",
  "version": "1.0.0",
  "description": "Shared resilience patterns for CascadeProjects - circuit breakers, retries, rate limiting",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./circuit-breaker": {
      "types": "./dist/circuit-breaker/index.d.ts",
      "default": "./dist/circuit-breaker/index.js"
    },
    "./retry": {
      "types": "./dist/retry/index.d.ts",
      "default": "./dist/retry/index.js"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit/index.d.ts",
      "default": "./dist/rate-limit/index.js"
    },
    "./health-check": {
      "types": "./dist/health-check/index.d.ts",
      "default": "./dist/health-check/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cascade/shared-types": "file:../shared-types"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.5.0",
    "vitest": "^1.0.0"
  }
}
