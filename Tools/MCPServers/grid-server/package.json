{
  "name": "grid-server",
  "version": "1.0.0",
  "description": "GATE envelope verification proxy MCP server — validates deployment envelopes and manages the transition gate pipeline",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "dev": "tsx --watch src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cascade/shared-resilience": "file:../../../Components/shared-resilience",
    "@cascade/shared-types": "file:../../../Components/shared-types",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "tsx": "^4.6.0",
    "typescript": "~6.0.2",
    "vitest": "4.1.5"
  }
}
