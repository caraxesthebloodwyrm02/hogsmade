# ori-server environment configuration
# Copy to .env and adjust paths for your machine.

# Required — workspace root (absolute path)
CASCADE_WORKSPACE_ROOT=$HOME/CascadeProjects

# Required — Echoes audit log location
ECHOES_AUDIT_PATH=$HOME/.echoes/audit.ndjson

# Optional — GRID API endpoint for merit guard
GRID_API_URL=http://localhost:8080

# Optional — override data directory (default: ~/.ori)
# ORI_DATA_DIR=$HOME/.ori

# Optional — override Echoes data directory (default: ~/.echoes)
# ECHOES_DATA_DIR=$HOME/.echoes

# Optional — external workspace roots for test discovery
# ORI_CANOPY_ROOT=$HOME/canopy
# ORI_ROOTS_ROOT=$HOME/roots
# ORI_GROVE_ROOT=$HOME/grove
