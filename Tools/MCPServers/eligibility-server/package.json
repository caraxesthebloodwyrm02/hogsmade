{
  "name": "eligibility-server",
  "version": "1.0.0",
  "description": "Dedicated MCP server for integration eligibility routines and multi-form compilation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "dev": "tsx --watch src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:modules": "tsx scripts/module-audit.ts",
    "pretest": "tsx scripts/module-audit.ts",
    "example": "tsx examples/complete-example.ts"
  },
  "dependencies": {
    "@cascade/shared-pipeline": "file:../../../Components/shared-pipeline",
    "@cascade/shared-types": "file:../../../Components/shared-types",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vitest": "4.1.4"
  }
}
