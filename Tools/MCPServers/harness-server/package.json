{
  "name": "harness-server",
  "version": "0.1.0",
  "description": "Agentic MCP server for the Great League harness pipeline — wraps the GATE Python harness, exposes scenario execution, transistor gate monitoring, signal collection, and autonomous agent loop management.",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx --watch src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cascade/shared-types": "file:../../../Components/shared-types",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "tsx": "^4.6.0",
    "typescript": "~6.0.2",
    "vitest": "4.1.5"
  }
}
