{
  "name": "glass",
  "version": "0.1.0",
  "description": "Spatial development environment",
  "homepage": "https://github.com/caraxesthebloodwyrm02/glass",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox --disable-gpu",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "snapshot": "uv run --with openpyxl python scripts/snapshot.py",
    "share:prep": "./scripts/prepare-share-drop.sh"
  },
  "keywords": [],
  "author": "caraxesthebloodwyrm02",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "electron": "41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "2.3.0",
    "typescript": "^5.5.0",
    "vite": "5.4.21",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "monaco-editor": "^0.55.1"
  }
}
