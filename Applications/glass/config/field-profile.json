{
  "profileName": "Default Glass Profile",
  "version": "1.0.0",
  "modulation": {
    "envelopes": {
      "ground": { "sustain": 0.12, "lfoRate": 0.04, "lfoDepth": 0.025 },
      "evaluating": { "sustain": 0.5, "lfoRate": 0.18, "lfoDepth": 0.07 },
      "floor_rising": { "sustain": 1.0, "lfoRate": 0.22, "lfoDepth": 0.04 },
      "voices_appearing": { "sustain": 0.85, "lfoRate": 0.12, "lfoDepth": 0.05 },
      "voice_1_active": { "sustain": 0.88, "lfoRate": 0.1, "lfoDepth": 0.06 },
      "voice_2_active": { "sustain": 0.88, "lfoRate": 0.13, "lfoDepth": 0.06 },
      "voice_3_active": { "sustain": 0.88, "lfoRate": 0.09, "lfoDepth": 0.06 },
      "elevated": { "sustain": 1.0, "lfoRate": 0.07, "lfoDepth": 0.03 },
      "returning": { "sustain": 0.25, "lfoRate": 0.06, "lfoDepth": 0.03 },
      "denied": { "sustain": 0.08, "lfoRate": 0.35, "lfoDepth": 0.1 }
    },
    "base": {
      "disk": { "scale": 0.06, "brightness": 0.04, "rimAlpha": 0.05 },
      "oval": { "opacity": 0.03, "lineWidth": 0.3, "markerAlpha": 0.04, "fieldAlpha": 0.02 },
      "voice": { "alpha": 0.0, "scanSpeed": 0.4, "glowRadius": 8 },
      "field": { "ambientIntensity": 0.28 },
      "block": { "levitationMod": 0.88 }
    },
    "recipe": {
      "disk": { "scale": 0.94, "brightness": 0.96, "rimAlpha": 0.95 },
      "oval": { "opacity": 0.72, "lineWidth": 2.1, "markerAlpha": 0.82, "fieldAlpha": 0.55 },
      "voice": { "alpha": 0.9, "scanSpeed": 1.8, "glowRadius": 18 },
      "field": { "ambientIntensity": 0.44 },
      "block": { "levitationMod": 0.12 }
    }
  },
  "ceremony": {
    "rarityGate": {
      "ground": "uncommon",
      "evaluating": "uncommon",
      "floor_rising": "rare",
      "voices_appearing": "epic",
      "voice_1_active": "epic",
      "voice_2_active": "epic",
      "voice_3_active": "epic",
      "elevated": "mythic",
      "returning": "rare",
      "denied": "common"
    }
  },
  "workflow": {
    "goalStatement": "Separate behavior from code so field personality and ceremony gating can evolve through structured data.",
    "hardConstraints": [
      "A single JSON profile remains the default source of truth for modulation and ceremony gating.",
      "The renderer stays sandboxed and receives profile data only through preload IPC.",
      "Asset rarity validation is enforced from loaded profile data in the main process.",
      "Typecheck, tests, and build must stay green as the profile surface expands."
    ],
    "functions": [
      {
        "id": "discover_profile",
        "label": "Discover Profile",
        "intent": "Collect hardcoded behavior maps and normalize them into reusable structured data.",
        "inputs": [
          "renderer modulation constants",
          "bridge rarity rules",
          "workspace profile findings"
        ],
        "outputs": ["field profile json", "shared schema", "validation path"]
      },
      {
        "id": "load_profile",
        "label": "Load Profile",
        "intent": "Resolve default and override profile sources while preserving safe fallbacks.",
        "inputs": ["GLASS_FIELD_PROFILE_PATH", "config/field-profile.json"],
        "outputs": ["validated field profile", "warning stream"]
      },
      {
        "id": "apply_modulation",
        "label": "Apply Modulation",
        "intent": "Route profile-driven envelope and bus data into the live field render loop.",
        "inputs": ["field profile modulation", "threshold state", "progress", "signal heat"],
        "outputs": ["bus values", "field animation"]
      },
      {
        "id": "enforce_rarity_gate",
        "label": "Enforce Rarity Gate",
        "intent": "Validate asset minting against the active ceremony ceiling from profile data.",
        "inputs": ["field profile ceremony", "asset metadata", "bridge threshold state"],
        "outputs": ["accepted asset block", "rejected mint warning"]
      }
    ],
    "lanes": [
      {
        "id": "source_of_truth",
        "label": "Source of Truth",
        "intent": "Keep the modulation map and ceremony gate editable as structured data.",
        "inputs": ["config/field-profile.json", "bridge/schema.ts"],
        "outputs": ["field profile schema", "validated defaults"],
        "discoveryRoom": [
          "alternate ceremony envelopes",
          "workspace-specific gates",
          "tunable field moods"
        ]
      },
      {
        "id": "runtime_wiring",
        "label": "Runtime Wiring",
        "intent": "Move validated profile data across main, preload, and renderer without breaking isolation.",
        "inputs": ["main process loader", "preload bridge", "renderer bootstrap"],
        "outputs": ["ipc handler", "window.glass.getFieldProfile", "profile-aware field startup"],
        "discoveryRoom": [
          "profile hot reload",
          "theme switching",
          "session-specific profile selection"
        ]
      },
      {
        "id": "ceremony_gate",
        "label": "Ceremony Gate",
        "intent": "Keep asset rarity policy untangled from shared bridge types and driven by loaded data.",
        "inputs": ["field profile ceremony", "bridge watcher"],
        "outputs": ["profile-driven rarity validation", "cleaner shared schema"],
        "discoveryRoom": [
          "rarity experimentation",
          "workspace policy presets",
          "test-specific gates"
        ]
      },
      {
        "id": "verification",
        "label": "Verification",
        "intent": "Preserve confidence while the profile surface grows and the data map evolves.",
        "inputs": ["vitest", "typecheck", "build", "snapshot export"],
        "outputs": ["passing pipeline", "structured evidence", "change safety"],
        "discoveryRoom": ["profile linting", "visual diff baselines", "config regression suites"]
      }
    ]
  },
  "engine": {
    "physics": {
      "pulseRadiusBase": 32,
      "pulseIntensityMod": 6,
      "transitionSpeedUp": 0.003,
      "transitionSpeedDown": 0.005
    },
    "visuals": {
      "ovalAlphaMod": 0.4,
      "slotIntensityMod": 3.5,
      "presenceAlphaBase": 0.3
    }
  }
}
