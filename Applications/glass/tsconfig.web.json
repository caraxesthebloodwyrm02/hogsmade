{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist/renderer",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src/renderer/**/*", "bridge/**/*"]
}
