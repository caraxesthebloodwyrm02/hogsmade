{
  "name": "glimpse-artifact",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "predev": "npm --prefix ../../Components/shared-types run build && node scripts/verify-rollup-platform.mjs",
    "dev": "vite",
    "prebuild": "npm --prefix ../../Components/shared-types run build && node scripts/verify-rollup-platform.mjs",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit --pretty false",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run lint && npm run test && npm run build",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "1.1.13",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^10.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.10",
    "rollup": "^4.34.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  }
}
