{
  "mcpServers": {
    "echoes-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/echoes-server/src/server.ts"],
      "env": {
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson"
      }
    },
    "grid-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/grid-server/src/server.ts"],
      "env": {
        "CASCADE_WORKSPACE_ROOT": "${workspaceFolder}",
        "GATE_DIR": "${workspaceFolder}/Projects/GATE",
        "GRID_API_URL": "http://localhost:8080"
      }
    },
    "afloat-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/afloat-server/src/server.ts"],
      "env": {}
    },
    "lots-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/lots-server/src/server.ts"],
      "env": {
        "LOTS_EXPERIMENTS_DIR": "${workspaceFolder}/experiments",
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson"
      }
    },
    "seeds-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/seeds-server/src/server.ts"],
      "env": {
        "SEEDS_ROOT": "${workspaceFolder}",
        "SEEDS_ROOTS": "${workspaceFolder},${env:HOME}/canopy,${env:HOME}/grove"
      }
    },
    "pulse-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/pulse-server/src/server.ts"],
      "env": {
        "GRID_API_URL": "http://localhost:8080"
      }
    },
    "grid-rag": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["mcp-setup/server/rag_mcp_server.py"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main",
        "RAG_EMBEDDING_PROVIDER": "ollama",
        "RAG_EMBEDDING_MODEL": "nomic-embed-text-v2-moe:latest",
        "RAG_LLM_MODE": "local",
        "RAG_LLM_MODEL_LOCAL": "ministral-3:latest",
        "RAG_VECTOR_STORE_PROVIDER": "chromadb",
        "RAG_VECTOR_STORE_PATH": "${workspaceFolder}/Projects/GRID-main/.rag_db",
        "OLLAMA_BASE_URL": "http://localhost:11434"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "ori-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/ori-server/src/server.ts"],
      "env": {
        "CASCADE_WORKSPACE_ROOT": "${workspaceFolder}",
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson",
        "GRID_API_URL": "http://localhost:8080"
      }
    },
    "grid-enhanced-tools": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["mcp-setup/server/enhanced_tools_mcp_server.py"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "portfolio-safety-lens": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["mcp-setup/server/portfolio_safety_mcp_server.py"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main:${env:HOME}/seed/archive/Coinbase_from_zip"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "code-analysis": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["mcp-setup/server/code_analysis_mcp_server.py"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main",
        "EXTRA_ALLOWED_ROOTS": "${workspaceFolder}"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "test-runner": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["mcp-setup/server/test_runner_mcp_server.py"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main",
        "EXTRA_ALLOWED_ROOTS": "${workspaceFolder}"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "maintain-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/maintain-server/src/server.ts"],
      "env": {
        "CASCADE_WORKSPACE_ROOT": "${workspaceFolder}",
        "SEEDS_ROOT": "${workspaceFolder}",
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson"
      }
    },
    "overview-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/overview-server/src/server.ts"],
      "env": {
        "CASCADE_WORKSPACE_ROOT": "${workspaceFolder}",
        "SEEDS_ROOT": "${workspaceFolder}",
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson",
        "GATE_DIR": "${workspaceFolder}/Projects/GATE"
      }
    },
    "grid-intelligence": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["-m", "grid.mcp.intelligence_server"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "grid-rag-enhanced": {
      "command": "${workspaceFolder}/Projects/GRID-main/.venv/bin/python",
      "args": ["-m", "grid.mcp.enhanced_rag_server"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/Projects/GRID-main/src:${workspaceFolder}/Projects/GRID-main",
        "RAG_EMBEDDING_PROVIDER": "ollama",
        "RAG_EMBEDDING_MODEL": "nomic-embed-text-v2-moe:latest",
        "RAG_LLM_MODE": "local",
        "RAG_LLM_MODEL_LOCAL": "ministral-3:latest",
        "RAG_VECTOR_STORE_PROVIDER": "chromadb",
        "RAG_VECTOR_STORE_PATH": "${workspaceFolder}/Projects/GRID-main/.rag_db",
        "OLLAMA_BASE_URL": "http://localhost:11434"
      },
      "cwd": "${workspaceFolder}/Projects/GRID-main"
    },
    "eligibility-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/eligibility-server/src/server.ts"],
      "env": {
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson",
        "ELIGIBILITY_DATA_DIR": "${env:HOME}/.eligibility-server"
      }
    },
    "harness-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/harness-server/src/server.ts"],
      "env": {
        "GATE_DIR": "${workspaceFolder}/Projects/GATE",
        "ECHOES_AUDIT_PATH": "${env:HOME}/.echoes/audit.ndjson",
        "GRID_API_URL": "http://localhost:8080"
      }
    },
    "nexus-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/nexus-server/src/index.ts"]
    },
    "school-server": {
      "command": "npx",
      "args": ["-y", "tsx", "${workspaceFolder}/Tools/MCPServers/school-server/src/index.ts"]
    }
  }
}
