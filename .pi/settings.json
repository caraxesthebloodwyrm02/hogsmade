{
  "defaultModel": "kimi-k2.5:cloud",
  "defaultProvider": "ollama",
  "defaultThinkingLevel": "low",
  "sessionDir": ".pi/sessions",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "maxDelayMs": 60000
  },
  "packages": [
    {
      "source": "../pi-mangrove",
      "extensions": ["extensions/dio-bridge.ts", "extensions/local-guard.ts"],
      "skills": [
        "skills/iterate/**",
        "skills/glimpse/**",
        "skills/lifeguard-review/**",
        "skills/trust-layer-review/**"
      ],
      "prompts": ["prompts/mangrove-dev.md", "prompts/tuv-review.md", "prompts/safety-gate.md"]
    }
  ]
}
