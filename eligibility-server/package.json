{
  "name": "eligibility-server",
  "version": "1.0.0",
  "description": "Dedicated MCP server for integration eligibility routines and multi-form compilation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "tsx src/server.ts",
