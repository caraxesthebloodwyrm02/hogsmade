{
  "name": "@cascade/shared-types",
  "version": "1.0.0",
  "description": "Shared schemas and utilities for CascadeProjects MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./audit-client": {
      "types": "./dist/audit-client.d.ts",
      "default": "./dist/audit-client.js"
    },
    "./security-policy": {
      "types": "./dist/security-policy.d.ts",
      "default": "./dist/security-policy.js"
    },
    "./session-rate-limit": {
      "types": "./dist/session-rate-limit.d.ts",
      "default": "./dist/session-rate-limit.js"
    },
    "./id": {
      "types": "./dist/id.d.ts",
      "default": "./dist/id.js"
    },
    "./mcp-logger": {
      "types": "./dist/mcp-logger.d.ts",
      "default": "./dist/mcp-logger.js"
    },
    "./precedent": {
      "types": "./dist/precedent.d.ts",
      "default": "./dist/precedent.js"
    },
    "./signal-model": {
      "types": "./dist/signal-model.d.ts",
      "default": "./dist/signal-model.js"
    },
    "./memory-ledger": {
      "types": "./dist/memory-ledger.d.ts",
      "default": "./dist/memory-ledger.js"
    },
    "./behavioral-schema": {
      "types": "./dist/behavioral-schema.d.ts",
      "default": "./dist/behavioral-schema.js"
    },
    "./trace-context": {
      "types": "./dist/trace-context.d.ts",
      "default": "./dist/trace-context.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit",
    "test": "node --test 'tests/**/*.test.mjs'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "~6.0.2",
    "vitest": "4.1.6"
  }
}
