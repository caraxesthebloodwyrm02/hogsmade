// Zed MCP server config reference — derived from mcp_config.json
// Copy the "context_servers" block into ~/.config/zed/settings.json
// Zed uses { command: { path, args, env } } format instead of { command, args, env }
// All Python server paths are absolutized (Zed has no cwd support)
//
// Last updated: 2026-03-21
{
  "context_servers": {
    "echoes-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/echoes-server/src/server.ts"],
        "env": {
          "ECHOES_AUDIT_PATH": "/home/caraxes/.echoes/audit.ndjson"
        }
      }
    },
    "grid-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/grid-server/src/server.ts"],
        "env": {
          "CASCADE_WORKSPACE_ROOT": "/home/caraxes/CascadeProjects",
          "GATE_DIR": "/home/caraxes/CascadeProjects/GATE",
          "GRID_API_URL": "http://localhost:8080"
        }
      }
    },
    "afloat-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/afloat-server/src/server.ts"],
        "env": {}
      }
    },
    "lots-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/lots-server/src/server.ts"],
        "env": {
          "LOTS_EXPERIMENTS_DIR": "/home/caraxes/CascadeProjects/experiments",
          "ECHOES_AUDIT_PATH": "/home/caraxes/.echoes/audit.ndjson"
        }
      }
    },
    "seeds-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/seeds-server/src/server.ts"],
        "env": {
          "SEEDS_ROOT": "/home/caraxes/seed"
        }
      }
    },
    "pulse-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/pulse-server/src/server.ts"],
        "env": {}
      }
    },
    "grid-rag": {
      "command": {
        "path": "/home/caraxes/roots/GRID/.venv/bin/python",
        "args": ["/home/caraxes/roots/GRID/mcp-setup/server/grid_rag_mcp_server.py"],
        "env": {
          "PYTHONPATH": "/home/caraxes/roots/GRID/src:/home/caraxes/roots/GRID",
          "RAG_EMBEDDING_PROVIDER": "ollama",
          "RAG_EMBEDDING_MODEL": "nomic-embed-text-v2-moe:latest",
          "RAG_LLM_MODE": "local",
          "RAG_LLM_MODEL_LOCAL": "ministral:latest",
          "RAG_VECTOR_STORE_PROVIDER": "chromadb",
          "RAG_VECTOR_STORE_PATH": "/home/caraxes/roots/GRID/.rag_db",
          "OLLAMA_BASE_URL": "http://localhost:11434"
        }
      }
    },
    "grid-rag-enhanced": {
      "command": {
        "path": "/home/caraxes/roots/GRID/.venv/bin/python",
        "args": ["-m", "grid.mcp.enhanced_rag_server"],
        "env": {
          "PYTHONPATH": "/home/caraxes/roots/GRID/src:/home/caraxes/roots/GRID",
          "RAG_EMBEDDING_PROVIDER": "ollama",
          "RAG_EMBEDDING_MODEL": "nomic-embed-text-v2-moe:latest",
          "RAG_LLM_MODE": "local",
          "RAG_LLM_MODEL_LOCAL": "ministral:latest",
          "RAG_VECTOR_STORE_PROVIDER": "chromadb",
          "RAG_VECTOR_STORE_PATH": "/home/caraxes/roots/GRID/.rag_db",
          "OLLAMA_BASE_URL": "http://localhost:11434"
        }
      }
    },
    "grid-enhanced-tools": {
      "command": {
        "path": "/home/caraxes/roots/GRID/.venv/bin/python",
        "args": ["/home/caraxes/roots/GRID/mcp-setup/server/enhanced_tools_mcp_server.py"],
        "env": {
          "PYTHONPATH": "/home/caraxes/roots/GRID/src:/home/caraxes/roots/GRID"
        }
      }
    },
    "portfolio-safety-lens": {
      "command": {
        "path": "/home/caraxes/roots/GRID/.venv/bin/python",
        "args": ["/home/caraxes/roots/GRID/mcp-setup/server/portfolio_safety_mcp_server.py"],
        "env": {
          "PYTHONPATH": "/home/caraxes/roots/GRID/src:/home/caraxes/roots/GRID:/home/caraxes/seed/archive/Coinbase_from_zip"
        }
      }
    },
    "code-analysis": {
      "command": {
        "path": "/home/caraxes/roots/GRID/.venv/bin/python",
        "args": ["/home/caraxes/roots/GRID/mcp-setup/server/code_analysis_mcp_server.py"],
        "env": {
          "PYTHONPATH": "/home/caraxes/roots/GRID/src:/home/caraxes/roots/GRID"
        }
      }
    },
    "test-runner": {
      "command": {
        "path": "/home/caraxes/roots/GRID/.venv/bin/python",
        "args": ["/home/caraxes/roots/GRID/mcp-setup/server/test_runner_mcp_server.py"],
        "env": {
          "PYTHONPATH": "/home/caraxes/roots/GRID/src:/home/caraxes/roots/GRID"
        }
      }
    },
    "maintain-server": {
      "command": {
        "path": "npx",
        "args": ["-y", "tsx", "/home/caraxes/CascadeProjects/maintain-server/src/server.ts"],
        "env": {
          "CASCADE_WORKSPACE_ROOT": "/home/caraxes/CascadeProjects",
          "SEEDS_ROOT": "/home/caraxes/seed",
          "ECHOES_AUDIT_PATH": "/home/caraxes/.echoes/audit.ndjson"
        }
      }
    }
  }
}
