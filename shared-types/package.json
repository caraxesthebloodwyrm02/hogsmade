{
  "name": "@cascade/shared-types",
  "version": "1.0.0",
  "description": "Shared schemas and utilities for CascadeProjects MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./audit-client": {
      "types": "./dist/audit-client.d.ts",
      "default": "./dist/audit-client.js"
    },
    "./security-policy": {
      "types": "./dist/security-policy.d.ts",
      "default": "./dist/security-policy.js"
    },
    "./session-rate-limit": {
      "types": "./dist/session-rate-limit.d.ts",
      "default": "./dist/session-rate-limit.js"
    },
    "./id": {
      "types": "./dist/id.d.ts",
      "default": "./dist/id.js"
    },
    "./mcp-logger": {
      "types": "./dist/mcp-logger.d.ts",
      "default": "./dist/mcp-logger.js"
    },
    "./precedent": {
      "types": "./dist/precedent.d.ts",
      "default": "./dist/precedent.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit",
    "test": "node --test 'tests/**/*.test.mjs'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
  }
}
