{
  "name": "@cascade/root",
  "version": "1.0.0",
  "private": true,
  "description": "Cascade monorepo — MCP servers, shared packages, and tooling",
  "type": "module",
  "workspaces": [
    "Components/shared-types",
    "Components/shared-resilience",
    "Components/shared-pipeline",
    "Tools/MCPServers/afloat-server",
    "Tools/MCPServers/echoes-server",
    "Tools/MCPServers/grid-server",
    "Tools/MCPServers/lots-server",
    "Tools/MCPServers/maintain-server",
    "Tools/MCPServers/overview-server",
    "Tools/MCPServers/pulse-server",
    "Tools/MCPServers/seeds-server",
    "Tools/MCPServers/ori-server",
    "Tools/MCPServers/eligibility-server",
    "Tools/MCPServers/harness-server",
    "Tools/MCPServers/nexus-server",
    "Tools/MCPServers/school-server",
    "Tools/MCPServers/glimpse-server",
    "Tools/MCPServers/mangrove-server",
    "Tools/MCPServers/craft-server",
    "Applications/pi-mangrove",
    "Applications/glimpse-artifact",
    "Applications/glimpse-engine"
  ],
  "scripts": {
    "postinstall": "node Components/scripts/init-submodules.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:all": "npm run --workspaces lint",
    "build:all": "npm run --workspaces build",
    "test:all": "npm run --workspaces test",
    "bootstrap:submodules": "node Components/scripts/init-submodules.mjs",
    "clean": "rm -rf */dist */build */coverage */.coverage */node_modules/.cache",
    "clean:deep": "npm run clean && rm -rf node_modules */node_modules",
    "version:bump": "node Components/scripts/version-bump.mjs",
    "release:notes": "node Components/scripts/generate-release-notes.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "protobufjs": ">=7.5.5",
    "basic-ftp": ">=5.2.2",
    "hono": ">=4.12.14",
    "fast-xml-parser": ">=5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/caraxesthebloodwyrm02/hogsmade.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/caraxesthebloodwyrm02/hogsmade/issues"
  },
  "homepage": "https://github.com/caraxesthebloodwyrm02/hogsmade#readme"
}
