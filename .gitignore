# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Generated or local-only outputs (keep status clean)
output/
tmp/
chart.csv
metadata.txt
snapshot.json

# Editor state (track .cursor/agents, .cursor/skills, .cursor/rules for sharing)
.agents/skills/
.claude/
.cursor/*
!.cursor/agents/
!.cursor/skills/
!.cursor/rules/
# Cursor hooks and local hook config (project-level hooks disabled; do not track)
.cursor/hooks/
.cursor/hooks.json
.windsurf/
.windsurf-next/
.antigravity/
.opencode/

# Debug and session state (IDE / agent logs)
debug-*.log
.session-state.json

# Secrets and local config
.env
.env.*
!.env.example
*.local

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Operational data: audit logs (append-only NDJSON). Intentionally not versioned.
# Echoes and other servers write here; git tracks source only.
*.ndjson

# Package manager caches
.pnpm-store/

# Security ownership map outputs and local venv (generated / machine-local)
ownership-map-out/
.tmp-ownership-venv/

# Orphan submodule path (no .gitmodules entry); keep local copy untracked
Atmosphere/

# Optional: local hook stubs (if re-added, keep empty or use .cursor/hooks.json)
hooks/
scripts/hooks/

# Local Netlify folder
.netlify

# Generated audit reports (local-only)
HARDCODED_AUDIT_REPORT.md
Audit Results and Todo Items.md

# Local configs
.gitconfig
zed_config.jsonc
config
config/
.vscode/

# Scratch / debug dumps (generated by CLI, not source)
gitlog.txt
gitlog_cmd.txt
gitstatus.txt
gitstatus_cmd.txt
gitremote.txt
gitremote_cmd.txt
2026-*.txt

# Demo drafts (not production)
demo-*.md

# MCP memory data (local-only, runtime-generated)
memory/

# Separate repos with their own .git (not submodules of this repo)
apiguard/
symphony-execution-performance/

# Glimpse server runtime (node_modules covered above, but be explicit)
glimpse-server/node_modules/
glimpse-server/dist/

# Shell dotfiles (WSL artifacts, not project files)
.bash_profile
.bashrc
.profile
.zprofile
.zshrc
.ripgreprc

# IDE / editor
.idea
.idea/

# MCP project-level config (may contain secrets)
.mcp.json

