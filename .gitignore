*-action-items.json
*-audit*.json
*-inventory.json
claude-progress.txt

# VS Code workspace files (machine-local)
*.code-workspace

# Local contract/config YAML (not source)
.response-discipline-contract.yaml

# Benchmark results (generated by glimpse-bench.py)
benchmarks/

# Session handoff notes (ephemeral, per-session)
docs/session-handoff-*.md

# Root-level duplicate docs (canonical copies live in docs/ or project dirs)
/GLIMPSE_BENCH.md
/UPWORK_CHROME_HANDOFF.md
/UPWORK_CONNECTS_PLAYBOOK.md
/UPWORK_STRATEGY_COMPLETE.md

# Projects scratch area — binary blobs, documents, demos, data files
