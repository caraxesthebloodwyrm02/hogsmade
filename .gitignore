# ==========================
# DEPENDENCIES
# ==========================
node_modules/
__pycache__/
*.pyc
.pyc
.venv/
venv/
.pnpm-store/
.yarn/
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================
# BUILD ARTIFACTS - TypeScript Monorepo
# ==========================
# Root-level build outputs
dist/
build/
*.tsbuildinfo
*.tsbuildinfo.*
.tscache/
.parcel-cache/
.rollup.cache/

# MCP Server build outputs (explicit per-server for safety)
*/dist/
*/build/
*/coverage/
*/.coverage/
*/coverage-unit/
*/coverage-integration/
**/coverage/
**/.coverage/

# Shared package build outputs
shared-types/dist/
shared-types/build/
shared-resilience/dist/
shared-resilience/build/
shared-pipeline/dist/
shared-pipeline/build/

# Glimpse artifact build outputs
glimpse-artifact/dist/
glimpse-artifact/build/
glimpse-artifact/.cache/

# Glimpse engine outputs
glimpse-engine/.glimpse-traces.jsonl
glimpse-engine/.glimpse-history.jsonl
glimpse-engine/.glimpse-activity.json

