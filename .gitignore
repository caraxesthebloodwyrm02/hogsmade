# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Editor state (track .cursor/agents, .cursor/skills, .cursor/rules for sharing)
.claude/
.cursor/*
!.cursor/agents/
!.cursor/skills/
!.cursor/rules/
# Cursor hooks and local hook config (project-level hooks disabled; do not track)
.cursor/hooks/
.cursor/hooks.json
.windsurf/

# Debug and session state (IDE / agent logs)
debug-*.log
.session-state.json

# Secrets and local config
.env
.env.*
*.local

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Operational data: audit logs (append-only NDJSON). Intentionally not versioned.
# Echoes and other servers write here; git tracks source only.
*.ndjson

# Package manager caches
.pnpm-store/

# Security ownership map outputs and local venv (generated / machine-local)
ownership-map-out/
.tmp-ownership-venv/

# Orphan submodule path (no .gitmodules entry); keep local copy untracked
Atmosphere/

# Optional: local hook stubs (if re-added, keep empty or use .cursor/hooks.json)
hooks/
scripts/hooks/

# Local Netlify folder
.netlify
