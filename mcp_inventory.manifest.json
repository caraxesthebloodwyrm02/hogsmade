{
  "version": "1.0.0",
  "description": "Supplements mcp_config.json with bootstrap contracts and explicit status for every GRID mcp-setup Python server (TUV-001 / .dev-rules.md). Editor canonical keys must match mcp_config.json mcpServers exactly.",
  "transportModel": {
    "editorCanonical": "stdio — all servers launched as child processes via editor MCP config (mcp_config.json / claude_code_config.json). No exposed ports.",
    "gridStandalone": "HTTP — GRID mcp-setup/mcp_config.json defines ports 8000-8009 with /health endpoints for standalone deployment. Not used by editor configs."
  },
  "paths": {
    "gridRepoRelativeToCascade": "../roots/GRID"
  },
  "servers": [
    {
      "mcpServerKey": "echoes-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "echoes-server/src/server.ts"
    },
    {
      "mcpServerKey": "grid-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "grid-server/src/server.ts"
    },
    {
      "mcpServerKey": "afloat-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "afloat-server/src/server.ts"
    },
    {
      "mcpServerKey": "lots-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "lots-server/src/server.ts"
    },
    {
      "mcpServerKey": "seeds-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "seeds-server/src/server.ts"
    },
    {
      "mcpServerKey": "pulse-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "pulse-server/src/server.ts"
    },
    {
      "mcpServerKey": "maintain-server",
      "runtime": "typescript",
      "bootstrapType": "mcp_sdk_stdio_ts",
      "entryRelative": "maintain-server/src/server.ts"
