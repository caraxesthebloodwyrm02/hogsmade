# Line endings: normalize to LF in repo; check out per OS.
* text=auto eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary / generated
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.webp binary
*.svg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
