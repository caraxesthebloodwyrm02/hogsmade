# Required machine-specific roots (replace $HOME with your actual home directory)
CASCADE_WORKSPACE_ROOT=$HOME/CascadeProjects
GATE_DIR=$HOME/CascadeProjects/Projects/GATE
LOTS_EXPERIMENTS_DIR=$HOME/CascadeProjects/experiments
SEEDS_ROOT=$HOME/CascadeProjects

# Optional integrations
GRID_API_URL=http://localhost:8080
ECHOES_AUDIT_PATH=$HOME/.echoes/audit.ndjson

# Optional data-dir overrides for local testing
# ECHOES_DATA_DIR=$HOME/.echoes
# AFLOAT_DATA_DIR=$HOME/.afloat
# PULSE_DATA_DIR=$HOME/.pulse
# SEEDS_DATA_DIR=$HOME/.seeds-server
# MAINTAIN_SCAN_ROOTS=$HOME/CascadeProjects,$HOME/seed

# Network Isolation (UNPROVISIONED MODE)
NETWORK_ISOLATION_MODE=unprovisioned
EXTERNAL_API_ACCESS=disabled
RATE_LIMIT_ENABLED=true
CIRCUIT_BREAKER_ENABLED=true

# Session Management
SESSION_HASH=REPLACE_WITH_GENERATED_HASH
AUDIT_SALT=REPLACE_WITH_GENERATED_SALT
