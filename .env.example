# Required machine-specific roots
CASCADE_WORKSPACE_ROOT=/home/caraxes/CascadeProjects
GATE_DIR=/home/caraxes/CascadeProjects/Projects/GATE
LOTS_EXPERIMENTS_DIR=/home/caraxes/CascadeProjects/experiments
SEEDS_ROOT=/home/caraxes/CascadeProjects

# Optional integrations
GRID_API_URL=http://localhost:8080
ECHOES_AUDIT_PATH=/home/caraxes/.echoes/audit.ndjson

# Optional data-dir overrides for local testing
# ECHOES_DATA_DIR=/home/caraxes/.echoes
# AFLOAT_DATA_DIR=/home/caraxes/.afloat
# PULSE_DATA_DIR=/home/caraxes/.pulse
# SEEDS_DATA_DIR=/home/caraxes/.seeds-server
# MAINTAIN_SCAN_ROOTS=/home/caraxes/CascadeProjects,/home/caraxes/seed

# Network Isolation (UNPROVISIONED MODE)
NETWORK_ISOLATION_MODE=unprovisioned
EXTERNAL_API_ACCESS=disabled
RATE_LIMIT_ENABLED=true
CIRCUIT_BREAKER_ENABLED=true

# Session Management
SESSION_HASH=REPLACE_WITH_GENERATED_HASH
AUDIT_SALT=REPLACE_WITH_GENERATED_SALT
